# Copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local sur GitHub

# Clé API Resend (resend.com) pour l'envoi des emails du formulaire de contact
RESEND_API_KEY=re_votre_cle_ici

# Email de réception des formulaires de contact
CONTACT_EMAIL=votre-email@exemple.com

# Avis Google en temps réel (optionnel)
# 1. Créer une clé sur https://console.cloud.google.com → API Places
# 2. Trouver votre Place ID sur https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACES_API_KEY=votre_cle_ici
GOOGLE_PLACE_ID=ChIJ_votre_place_id_ici
